# Vibe Voice Configuration
# Copy this file to .env and adjust values

# Server configuration
NODE_ENV=production
PORT=3000

# Storage paths (inside containers)
STORAGE_PATH=/storage/tts-output
DATABASE_PATH=/data/vibe-voice.db

# Piper TTS connection
PIPER_HOST=piper
PIPER_PORT=10200

# Job processing
# Number of concurrent TTS jobs (1-2 recommended for CPU-only)
CONCURRENT_JOBS=1

# Voice settings (these are defaults, can be overridden per-job)
DEFAULT_VOICE=de-thorsten-medium
DEFAULT_SPEED=1.0

# Rate limiting (optional)
# Requests per 15 minutes
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=50

# Upload limits (bytes)
MAX_FILE_SIZE=52428800

# Optional: For future expansion with auth
# JWT_SECRET=your-secret-key-here
